<Window x:Class="Wpfdemo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WPF EF Core MVVM Demo"
        Height="500"
        Width="800">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Window.Resources>

    <Grid>
        <ContentControl Content="{Binding CurrentViewModel}"/>

        <Border Background="#66000000"
                Visibility="{Binding IsMenuOpen, Converter={StaticResource BoolToVisibilityConverter}}">
            <Button Command="{Binding CloseMenuCommand}"
                    Background="Transparent"
                    BorderThickness="0"/>
        </Border>

        <Border Width="260"
                Background="White"
                BorderBrush="#DDDDDD"
                BorderThickness="1,0,0,0"
                HorizontalAlignment="Right"
                Visibility="{Binding IsMenuOpen, Converter={StaticResource BoolToVisibilityConverter}}">

            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <DockPanel Margin="0,0,0,25">
                    <TextBlock Text="Menu"
                               FontSize="24"
                               FontWeight="Bold"
                               DockPanel.Dock="Left"/>

                    <Button Content="X"
                            Width="35"
                            Height="35"
                            Command="{Binding CloseMenuCommand}"
                            HorizontalAlignment="Right"/>
                </DockPanel>

                <StackPanel Grid.Row="1">
                    <Button Content="Products"
                            Height="45"
                            Margin="0,0,0,10"
                            Command="{Binding OpenProductsCommand}"/>

                    <Button Content="Page Two"
                            Height="45"
                            Margin="0,0,0,10"
                            Command="{Binding OpenPageTwoCommand}"/>

                    <Button Content="Page Three"
                            Height="45"
                            Command="{Binding OpenPageThreeCommand}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>